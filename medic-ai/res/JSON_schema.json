    "clinical_category": (assign 'treatment', 'diagnosis', or 'procedure' based on basic keyword matching in the text),
    "text_content": (the full chunked narrative text),
    "extracted_tables": (any arrays pulled by pdfplumber for this section),
    "page_reference": [page numbers
    ]
}


